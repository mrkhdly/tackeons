{
  "name": "tackeons",
  "version": "0.1.0",
  "description": "A streamlined, self-contained fork of Tachyons CSS",
  "author": "mrkhdly <mark@grey.cx>",
  "homepage": "https://github.com/mrkhdly/tackeons",
  "bugs": "https://github.com/mrkhdly/tackeons/issues",
  "style": "css/tackeons.min.css",
  "main": "css/tackeons.css",
  "files": [
    "css",
    "src"
  ],
  "repository": "mrkhdly/tackeons",
  "keywords": [
    "UI",
    "UI design",
    "css",
    "oocss",
    "postcss",
    "functional css",
    "utility css",
    "design",
    "responsive",
    "performance"
  ],
  "license": "MIT",
  "devDependencies": {
    "cssnano": "^7.0.0",
    "immutable-css-cli": "^1.1.1",
    "postcss": "^8.4.0",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.0.0",
    "watch": "^1.0.2"
  },
  "contributors": [
    {
      "name": "Adam Morse",
      "url": "https://mrmrs.cc"
    },
    {
      "name": "John Otander",
      "url": "https://johnotander.com"
    }
  ],
  "scripts": {
    "start": "npm run build:watch",
    "mutations": "immutable-css src/tackeons.css --strict",
    "build": "npm run build:css && npm run build:minify",
    "build:css": "postcss src/tackeons.css -o css/tackeons.css",
    "build:minify": "postcss src/tackeons.css -o css/tackeons.min.css --env minify",
    "build:watch": "watch \"npm run build\" ./src/",
    "size": "node -e \"const z=require('zlib'),f=require('fs');console.log('brotli:',z.brotliCompressSync(f.readFileSync('css/tackeons.min.css')).length,'bytes')\""
  },
  "dependencies": {
    "gzip-size": "^7.0.0"
  }
}
